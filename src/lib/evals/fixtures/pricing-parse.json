[
  {
    "id": "amazon-hit",
    "source": "amazon",
    "description": "Three Amazon organic results with extracted_price — should average",
    "input": {
      "organic_results": [
        { "extracted_price": 899.99, "link": "https://www.amazon.com/dp/ABC123" },
        { "extracted_price": 849.00, "asin": "DEF456" },
        { "extracted_price": 920.00, "link": "https://www.amazon.com/dp/GHI789" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 890,
      "sourceCount": 3,
      "notes": "Average of 899.99+849+920 = 889.66, rounded to 890"
    }
  },
  {
    "id": "amazon-price-string-fallback",
    "source": "amazon",
    "description": "Amazon results with price string instead of extracted_price — should parse correctly",
    "input": {
      "organic_results": [
        { "price": "$1,299.00", "link": "https://www.amazon.com/dp/XYZ" },
        { "price": "$1,199.99", "link": "https://www.amazon.com/dp/ABC" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 1250,
      "sourceCount": 2,
      "notes": "Average of 1299+1199.99 = 1249.50, rounded to 1250"
    }
  },
  {
    "id": "walmart-hit",
    "source": "walmart",
    "description": "Walmart organic results with primary_price — should average",
    "input": {
      "organic_results": [
        { "primary_price": 499.00, "product_page_url": "https://www.walmart.com/ip/product-a/123" },
        { "primary_price": 479.00, "product_page_url": "https://www.walmart.com/ip/product-b/456" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 489,
      "sourceCount": 2,
      "notes": "Average of 499+479 = 489"
    }
  },
  {
    "id": "home-depot-hit",
    "source": "home_depot",
    "description": "Home Depot products with price — should average",
    "input": {
      "products": [
        { "price": 249.00, "link": "https://www.homedepot.com/p/product-a/123" },
        { "price": 279.00, "link": "https://www.homedepot.com/p/product-b/456" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 264,
      "sourceCount": 2,
      "notes": "Average of 249+279 = 264"
    }
  },
  {
    "id": "amazon-no-results",
    "source": "amazon",
    "description": "Empty organic_results array — should return null",
    "input": {
      "organic_results": []
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "No results"
    }
  },
  {
    "id": "amazon-missing-key",
    "source": "amazon",
    "description": "Response with no organic_results key — should return null gracefully",
    "input": {},
    "expected": {
      "hit": false,
      "price": null,
      "notes": "Missing organic_results key — parser should not throw"
    }
  },
  {
    "id": "amazon-no-prices",
    "source": "amazon",
    "description": "Results present but none have a parseable price — should return null",
    "input": {
      "organic_results": [
        { "title": "Some product", "link": "https://www.amazon.com/dp/ABC" },
        { "title": "Another product", "asin": "XYZ789" }
      ]
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "Results present but no price fields — should return null"
    }
  }
]
