[
  {
    "id": "ebay-electronics-hit",
    "source": "ebay",
    "description": "Three sold listings for a Sony TV — should average and return sources",
    "input": {
      "findCompletedItemsResponse": [
        {
          "searchResult": [
            {
              "item": [
                {
                  "sellingStatus": [{ "currentPrice": [{ "__value__": "420.00" }] }],
                  "viewItemURL": ["https://www.ebay.com/itm/111111"]
                },
                {
                  "sellingStatus": [{ "currentPrice": [{ "__value__": "380.00" }] }],
                  "viewItemURL": ["https://www.ebay.com/itm/222222"]
                },
                {
                  "sellingStatus": [{ "currentPrice": [{ "__value__": "460.00" }] }],
                  "viewItemURL": ["https://www.ebay.com/itm/333333"]
                }
              ]
            }
          ]
        }
      ]
    },
    "expected": {
      "hit": true,
      "price": 420,
      "sourceCount": 3,
      "notes": "Average of 420+380+460 = 420, rounded"
    }
  },
  {
    "id": "ebay-no-listings",
    "source": "ebay",
    "description": "Empty search result — should return null",
    "input": {
      "findCompletedItemsResponse": [
        {
          "searchResult": [
            { "item": [] }
          ]
        }
      ]
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "No sold listings found"
    }
  },
  {
    "id": "ebay-missing-result-key",
    "source": "ebay",
    "description": "API response with missing searchResult — should return null gracefully",
    "input": {
      "findCompletedItemsResponse": [{}]
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "Missing searchResult key — parser should not throw"
    }
  },
  {
    "id": "ebay-single-listing",
    "source": "ebay",
    "description": "Single listing — price should equal that listing's price",
    "input": {
      "findCompletedItemsResponse": [
        {
          "searchResult": [
            {
              "item": [
                {
                  "sellingStatus": [{ "currentPrice": [{ "__value__": "199.99" }] }],
                  "viewItemURL": ["https://www.ebay.com/itm/444444"]
                }
              ]
            }
          ]
        }
      ]
    },
    "expected": {
      "hit": true,
      "price": 200,
      "sourceCount": 1,
      "notes": "Single listing, Math.round(199.99) = 200"
    }
  },
  {
    "id": "serp-shopping-hit",
    "source": "serp",
    "description": "Three Google Shopping results with extracted_price — should average",
    "input": {
      "shopping_results": [
        { "extracted_price": 899.99, "product_link": "https://www.amazon.com/dp/ABC123" },
        { "extracted_price": 849.00, "product_link": "https://www.bestbuy.com/site/product/123" },
        { "extracted_price": 920.00, "product_link": "https://www.walmart.com/ip/456" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 890,
      "sourceCount": 3,
      "notes": "Average of 899.99+849+920 = 889.66, rounded to 890"
    }
  },
  {
    "id": "serp-price-string-fallback",
    "source": "serp",
    "description": "Results with price string instead of extracted_price — should parse correctly",
    "input": {
      "shopping_results": [
        { "price": "$1,299.00", "link": "https://www.amazon.com/dp/XYZ" },
        { "price": "$1,199.99", "link": "https://www.walmart.com/ip/789" }
      ]
    },
    "expected": {
      "hit": true,
      "price": 1250,
      "sourceCount": 2,
      "notes": "Average of 1299+1199.99 = 1249.50, rounded to 1250; uses link fallback when product_link absent"
    }
  },
  {
    "id": "serp-no-results",
    "source": "serp",
    "description": "Empty shopping_results array — should return null",
    "input": {
      "shopping_results": []
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "No shopping results"
    }
  },
  {
    "id": "serp-missing-key",
    "source": "serp",
    "description": "Response with no shopping_results key — should return null gracefully",
    "input": {},
    "expected": {
      "hit": false,
      "price": null,
      "notes": "Missing shopping_results key — parser should not throw"
    }
  },
  {
    "id": "serp-no-prices",
    "source": "serp",
    "description": "Results present but none have a parseable price — should return null",
    "input": {
      "shopping_results": [
        { "title": "Some product", "link": "https://example.com/product" },
        { "title": "Another product", "product_link": "https://example.com/other" }
      ]
    },
    "expected": {
      "hit": false,
      "price": null,
      "notes": "Results exist but no price fields — should not throw or return a price"
    }
  }
]
